# ===========================================
# AI PR Reviewer Bot — Environment Variables
# ===========================================

# --- Server Configuration ---
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# --- AI Provider Configuration ---
# Which AI provider to use: "gemini" | "ollama" | "claude" | "openrouter"
AI_PROVIDER=gemini

# Google Gemini API Key (required when AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# The specific model to use for inference
AI_MODEL=gemini-2.5-flash

# Set to "paid" if you have a paid Gemini tier to enable parallel processing
# Leave as "free" (or empty) to enforce sequential processing and avoid 429 Rate Limits
GEMINI_TIER=free

# --- Ollama Configuration (when AI_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-coder-v2

# --- Claude Configuration (when AI_PROVIDER=claude) ---
# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- OpenRouter Configuration (when AI_PROVIDER=openrouter) ---
# OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- GitHub Configuration ---
# GitHub App Configuration (Primary - Highly Recommended)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_BASE64=

# Webhook secret configured in your GitHub App/webhook settings
# (Required in production)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub Personal Access Token (Fallback/Dev-only)
GITHUB_TOKEN=ghp_your_github_token_here

# Whether to post review findings as comments back to the PR
POST_REVIEW_TO_GITHUB=false

# --- Redis Configuration ---
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# --- Database Configuration ---
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/ai_reviewer?schema=public"

# --- Review Thresholds ---
# Minimum confidence percentage to include a finding in the output
MIN_CONFIDENCE_THRESHOLD=85

# Maximum diff lines before the engine applies aggressive chunking
MAX_DIFF_LINES=5000
