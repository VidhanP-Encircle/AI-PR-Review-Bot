{
  "name": "ai-pr-reviewer",
  "version": "0.1.0",
  "description": "AI PR Reviewer Bot — Staff Engineer-level automated code reviews",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "ai-review": "dist/cli.js"
  },
  "scripts": {
    "dev:all": "concurrently \"docker-compose up\" \"npm run dev:server\" \"npm run dev --prefix dashboard\"",
    "dev": "tsx src/cli.ts",
    "dev:server": "tsx watch src/server.ts",
    "start:server": "tsx src/server.ts",
    "tunnel": "npx localtunnel --port 3001",
    "review:online": "tsx scripts/trigger-review.ts",
    "build": "tsup src/cli.ts src/server.ts --format esm --dts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "promptfoo eval -c eval/promptfooconfig.yaml"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.1.0",
    "@google/generative-ai": "^0.24.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^21.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@swc/core": "^1.15.43",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.30.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "fastify-raw-body": "^5.0.0",
    "glob": "^13.0.6",
    "next-auth": "^4.24.14",
    "p-limit": "^7.3.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "tree-sitter": "^0.21.1",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-c-sharp": "^0.23.5",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-dart": "^1.0.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-scala": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "yaml": "^2.6.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "concurrently": "^10.0.3",
    "prisma": "^7.8.0",
    "promptfoo": "^0.121.17",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "allowScripts": {
    "tree-sitter@0.21.1": true,
    "tree-sitter-c@0.24.1": true,
    "tree-sitter-c@0.23.6": true,
    "tree-sitter-c-sharp@0.23.5": true,
    "tree-sitter-cpp@0.23.4": true,
    "tree-sitter-dart@1.0.0": true,
    "tree-sitter-go@0.25.0": true,
    "tree-sitter-java@0.23.5": true,
    "tree-sitter-javascript@0.23.1": true,
    "tree-sitter-kotlin@0.3.8": true,
    "tree-sitter-php@0.24.2": true,
    "tree-sitter-python@0.25.0": true,
    "tree-sitter-ruby@0.23.1": true,
    "tree-sitter-rust@0.24.0": true,
    "tree-sitter-scala@0.24.0": true,
    "tree-sitter-typescript@0.23.2": true
  }
}
